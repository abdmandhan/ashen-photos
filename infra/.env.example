# Ashen Photos — infra config
# Phase 1 uses shared services on nuc.test (not self-hosted via docker compose).
# Copy to infra/.env and adjust as needed.

# --- Postgres ---
POSTGRES_HOST=nuc.test
POSTGRES_PORT=5433
POSTGRES_USER=default
POSTGRES_PASSWORD=secret
POSTGRES_DB=ashen
DATABASE_URL=postgres://default:secret@nuc.test:5433/ashen?sslmode=disable

# --- Redis ---
REDIS_HOST=nuc.test
REDIS_PORT=6379
REDIS_PASSWORD=secret_redis
REDIS_URL=redis://:secret_redis@nuc.test:6379/0

# --- MinIO / S3 ---
MINIO_ENDPOINT=nuc.test:9000
MINIO_CONSOLE=nuc.test:9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadminpassword
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
S3_BUCKET_PHOTOS=ashen-photos
S3_BUCKET_VIDEOS=ashen-videos
S3_BUCKET_THUMBNAILS=ashen-thumbnails

# --- Auth ---
JWT_SECRET=change-me-in-prod
